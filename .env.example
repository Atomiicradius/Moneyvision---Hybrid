# FinIntel Hybrid — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Market Data ───────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# Free key: https://www.alphavantage.co/support/#api-key

# ── LLM (choose one) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
# Free Groq key: https://console.groq.com/

# ── PostgreSQL + pgvector (Phase 2) ──────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:password@localhost:5432/finintel

# ── Google Vision OCR (Phase 2 — optional) ───────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# ── Tesseract (Windows path override) ────────────────────────────────────────
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
